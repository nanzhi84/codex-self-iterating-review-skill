{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "changed_files",
    "notes"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "applied",
        "partial",
        "blocked",
        "no-op"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
