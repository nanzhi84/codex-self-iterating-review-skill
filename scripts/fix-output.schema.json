{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "changed_files",
    "finding_results",
    "notes"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "applied",
        "partial",
        "blocked",
        "no-op"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "finding_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fingerprint",
          "status",
          "summary",
          "reason"
        ],
        "properties": {
          "fingerprint": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "fixed",
              "partially_fixed",
              "blocked",
              "invalid",
              "needs_business_confirmation",
              "no_progress"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
