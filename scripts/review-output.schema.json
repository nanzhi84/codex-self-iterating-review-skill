{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "round_summary",
    "findings",
    "business_questions"
  ],
  "properties": {
    "round_summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "title",
          "confidence",
          "file",
          "line_start",
          "line_end",
          "why",
          "repro_or_evidence",
          "fix_strategy",
          "fingerprint_basis",
          "requires_business_confirmation",
          "business_question"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "P1",
              "P2",
              "P3",
              "P4"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "file": {
            "type": [
              "string",
              "null"
            ]
          },
          "line_start": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "line_end": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "why": {
            "type": "string",
            "minLength": 1
          },
          "repro_or_evidence": {
            "type": "string",
            "minLength": 1
          },
          "fix_strategy": {
            "type": "string",
            "minLength": 1
          },
          "fingerprint_basis": {
            "type": "string",
            "minLength": 1
          },
          "requires_business_confirmation": {
            "type": "boolean"
          },
          "business_question": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "business_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "file",
          "question",
          "blocked_findings"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": [
              "string",
              "null"
            ]
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "blocked_findings": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
